# =============================================
# MIND OS Backend — переменные окружения
# =============================================
# Скопируй этот файл в .env и заполни своими данными.
# НИКОГДА не добавляй .env в Git!

# Django
SECRET_KEY=your-very-secret-key-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=mindos_db
DB_USER=mindos_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Render API
RENDER_API_KEY=your_render_api_key_here

