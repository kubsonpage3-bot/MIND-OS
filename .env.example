# =============================================
# MIND OS Frontend — переменные окружения
# =============================================
# Скопируй этот файл в .env (или .env.local) и заполни своими данными.
# НИКОГДА не добавляй .env файлы с секретами в Git!

# Базовый URL для API бэкенда.
# Оставь пустым, если бэкенд и фронтенд работают на одном домене, 
# и запросы должны идти на /api/
VITE_API_URL=

# Базовый origin (домен) для API, если он нужен для других сервисов.
# Например: https://api.mindosgrowth.org
VITE_API_ORIGIN=
